generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/* --- NextAuth base models --- */
model User {
  id            String   @id @default(cuid())
  name          String?
  email         String?  @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String? // for Credentials login

  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Domain models to migrate from SQLite progressively
model Member {
  id               String   @id @default(cuid())
  userId           String   @unique
  stripeCustomerId String?  @unique
  status           String   @default("active")
  delinquentSince  DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Membership {
  id                     String   @id @default(cuid())
  memberId               String
  stripeSubscriptionId   String   @unique
  planCode               String
  currentPeriodEnd       DateTime
  status                 String
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model ClassTemplate {
  id             String   @id @default(cuid())
  name           String
  coachName      String?
  capacityDefault Int
  rrule          String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ClassInstanceP {
  id          String   @id @default(cuid())
  templateId  String?
  title       String
  coachName   String?
  startsAt    DateTime
  endsAt      DateTime
  capacity    Int
  status      String   @default("scheduled")
  color       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BookingP {
  id              String   @id @default(cuid())
  classInstanceId String
  memberId        String
  status          String   @default("booked")
  bookedAt        DateTime @default(now())
  canceledAt      DateTime?
}

model PaymentP {
  id        String   @id @default(cuid())
  memberId  String
  amount    Int
  currency  String   @default("cad")
  status    String   @default("completed")
  createdAt DateTime @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @map("refresh_token")
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/* --- Example domain table (keep for later) --- */
model Class {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  image       String?
  durationMin Int?
  priceCents  Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
